{
	"expo": {
		"name": "Estate Code Generator",
		"slug": "my-expo-app",
		"version": "1.0.0",
		"scheme": "my-expo-app",
		"web": {
			"bundler": "metro",
			"output": "static",
			"image": "./src/assets/gatepass_ng_Gp.png",
			"favicon": "./src/assets/gatepass_ng_Gp.png"
		},
		"plugins": ["expo-router", "expo-font", "expo-web-browser"],
		"experiments": {
			"typedRoutes": true,
			"tsconfigPaths": true
		},
		"orientation": "portrait",
		"icon": "./src/assets/gatepass_ng_Gp.png",
		"userInterfaceStyle": "automatic",
		"splash": {
			"image": "./src/assets/gatepass_ng_Gp.png",
			"resizeMode": "cover",
			"backgroundColor": "#ffffff"
		},
		"assetBundlePatterns": ["**/*"],
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.specialone.gms"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./src/assets/gatepass_ng_Gp.png",
				"backgroundColor": "#ffffff"
			},
			"package": "com.specialone.gms"
		}
	}
}
