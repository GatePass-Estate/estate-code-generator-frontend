{
	"expo": {
		"name": "Gate Pass",
		"slug": "my-expo-app",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./src/assets/gatepass_ng_Gp.png",
		"splash": {
			"image": "./src/assets/splash.png",
			"resizeMode": "contain",
			"backgroundColor": "#ffffff" // or whatever solid colour you want behind the image
		},
		"plugins": [
			[
				"expo-splash-screen",
				{
					// These settings disable the default Android/iOS splash layout (shadow + text)
					"enable": true,
					"backgroundColor": "#ffffff",
					"image": "./assets/splash.png",
					"imageWidth": 200, // width of your logo inside the splash
					"resizeMode": "contain",

					// This is the important part — disables the built-in UI
					"androidDisableDefaultSplashLayout": true,
					"iosDisableDefaultSplashStoryboard": true,

					// Optional: completely hide the app name on Android
					"hideAppNameOnAndroid": true,

					"dark": {
						"image": "./assets/splash-dark.png", // optional
						"backgroundColor": "#000000"
					}
				}
			]
		],
		"android": {
			"package": "com.specialone.gms",
			"adaptiveIcon": {
				"foregroundImage": "./src/assets/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			}
		},
		"ios": {
			"bundleIdentifier": "com.specialone.gms"
		}
	}
}
