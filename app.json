{
  "expo": {
    "name": "GatePass",
    "slug": "gatepass",
    "owner": "gatepassng",
    "version": "1.0.0",
    "scheme": "gatepass",
    "orientation": "portrait",
    "icon": "./src/assets/gatepass_ng_Gp.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/gatepass_ng_Gp.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000",
      "color": "#000000"
    },
    "android": {
      "package": "com.gatepassng.gms",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/gatepass_ng_Gp.png",
        "backgroundColor": "#000000"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.gatepassng.com",
              "pathPrefix": "/activate"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "gatepass",
              "host": "*",
              "pathPrefix": "/auth/reset-password"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gatepassng.gms",
      "associatedDomains": [
        "applinks:app.gatepassng.com"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "image": "./src/assets/gatepass_ng_Gp.png",
      "favicon": "./src/assets/gatepass_ng_Gp.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./src/assets/gatepass_ng_Gp.png",
          "dark": {
            "image": "./src/assets/gatepass_ng_Gp.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af7a228b-45e8-4505-bbef-4e9288d902e9"
      }
    }
  }
}
